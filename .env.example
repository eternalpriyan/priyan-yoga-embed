# Oclass API — server-side ONLY. NEVER expose to the browser.
# This token is full-access (reads PII, payroll, can mutate). The serverless
# functions must only ever return a hand-picked allowlist of fields.
OCLASS_API_TOKEN=

# Comma-separated allowed origins for CORS. Set to your live site in production.
# Use "*" only while testing. Example: https://priyan.yoga,https://www.priyan.yoga
ALLOW_ORIGIN=*

# Public Oclass booking site base, used to build "Enrol" links on course cards.
ENROLL_BASE=https://clients.oclass.app/priyan-yoga
